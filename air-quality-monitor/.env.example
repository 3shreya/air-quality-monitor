# Air Quality Analytics — Environment Variables
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────
# OpenAQ API (Optional — raises rate limits)
# Get your free key at: https://docs.openaq.org
# ─────────────────────────────────────────────
OPENAQ_API_KEY=your_api_key_here

# ─────────────────────────────────────────────
# App Settings
# ─────────────────────────────────────────────
APP_DEBUG=false
LOG_LEVEL=INFO
